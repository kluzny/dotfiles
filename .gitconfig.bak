[user]
  name =
  email =
[alias]
  lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
  ls = diff --name-status master
  last = log -1 HEAD --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
  st = status
  br = branch
  undo = reset --soft HEAD^
  unstage = restore --staged
  amend = commit --amend
  delete = branch -D
  search = log -S
  update = remote -v update
  continue = rebase --continue
  cached = diff --cached
[core]
  excludesfile = /home/dir/.gitignore
  editor = /usr/local/bin/vim
[push]
  default = matching
